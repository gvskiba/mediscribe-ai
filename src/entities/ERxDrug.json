{
  "name": "ERxDrug",
  "type": "object",
  "properties": {
    "drug_id": {
      "type": "string",
      "description": "Unique drug identifier (e.g., 'ibuprofen', 'amoxicillin')"
    },
    "name": {
      "type": "string",
      "description": "Generic drug name"
    },
    "brand": {
      "type": "string",
      "description": "Brand name(s)"
    },
    "cls": {
      "type": "string",
      "description": "Drug class (e.g., NSAID, Beta-blocker, ACE Inhibitor)"
    },
    "emoji": {
      "type": "string",
      "description": "Emoji for UI display"
    },
    "forms": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Available formulations (e.g., tablet, liquid, injection)"
    },
    "sigs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Common SIG instructions (e.g., PO BID, IV Q6h)"
    },
    "controlled": {
      "type": "boolean",
      "default": false,
      "description": "Whether this is a controlled substance"
    },
    "sch": {
      "type": "integer",
      "description": "DEA schedule (1-5, null for non-controlled)"
    },
    "renal": {
      "type": "string",
      "description": "Renal dosing adjustment guidance"
    },
    "hepatic": {
      "type": "string",
      "description": "Hepatic dosing adjustment guidance"
    },
    "interactions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "List of drugs/classes this drug interacts with"
    },
    "allergies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Cross-reactivity allergy references (e.g., penicillin class)"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Clinical warnings or contraindications"
    },
    "category": {
      "type": "string",
      "description": "Drug category (e.g., pain, infection, cardiac)"
    },
    "notes": {
      "type": "string",
      "description": "Additional clinical notes"
    }
  },
  "required": [
    "drug_id",
    "name"
  ]
}